        <mxCell id="vercel" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontSize=10;fontColor=#1e3a5f;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;shadow=1;" value="&lt;b&gt;Vercel&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;b&gt;Next.js 16 App Router&lt;/b&gt;&lt;br&gt;━━━━━━━━━━━━━━&lt;br&gt;Dashboard (React 19)&lt;br&gt;API Routes (Serverless)&lt;br&gt;━━━━━━━━━━━━━━&lt;br&gt;• Runner API (/api/runner/*)&lt;br&gt;• Webhook API (/api/webhooks/*)&lt;br&gt;• GitHub API (/api/github/*)&lt;br&gt;• Cron API (/api/cron/*)" vertex="1">
          <mxGeometry height="240" width="280" x="340" y="280" as="geometry" />
