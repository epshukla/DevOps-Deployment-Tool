        <mxCell id="supabase" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=2;fontSize=10;fontColor=#064e3b;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;shadow=1;" value="&lt;b&gt;Supabase&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;b&gt;PostgreSQL + Services&lt;/b&gt;&lt;br&gt;━━━━━━━━━━━━━━&lt;br&gt;• PostgreSQL (29 tables, RLS)&lt;br&gt;• Auth (GitHub OAuth, PKCE)&lt;br&gt;• Realtime (10 tables)&lt;br&gt;• Storage (build artifacts)&lt;br&gt;• Edge Functions&lt;br&gt;━━━━━━━━━━━━━━&lt;br&gt;84 RLS policies&lt;br&gt;17 enums, 7 functions" vertex="1">
          <mxGeometry height="240" width="280" x="680" y="280" as="geometry" />
